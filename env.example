# Target instrument (e.g. BTC_USD, EUR_USD, GBP_USD)
INSTRUMENT=BTC_USD

# Mode of operation: simulator, demo (Oanda Practice), real (Oanda Live)
BOT_MODE=simulator

# Allora Network API Topic ID (Topic 14 represents BTC_USD predictions)
ALLORA_TOPIC_ID=14

# Allora Chain ID (e.g. Sepolia testnet "ethereum-11155111")
ALLORA_CHAIN_ID=ethereum-11155111

# Your Allora API key (Optional for simulator mode, required if Use Allora AI is toggled)
ALLORA_KEY=

# Oanda API personal token (Required for demo/real modes)
OANDA_KEY=

# Oanda Account ID (Auto-discovered if blank)
OANDA_ACCOUNT_ID=
